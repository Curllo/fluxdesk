{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FluxDesk",
  "version": "1.1.0",
  "identifier": "com.fluxdesk.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "command-center",
        "title": "FluxDesk",
        "width": 1280,
        "height": 800,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": true,
        "visible": true,
        "center": true,
        "skipTaskbar": false,
        "resizable": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' blob: https://registry.npmmirror.com 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:* http://127.0.0.1:* https://api.open-meteo.com https://geocoding-api.open-meteo.com https://air-quality-api.open-meteo.com; img-src 'self' data: blob:; frame-src 'self' blob: data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["bin/fluxdesk-ai"],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "startMenuFolder": "FluxDesk"
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "librsvg2-2",
          "libsoup-3.0-0",
          "libjavascriptcoregtk-4.1-0"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/fluxdesk/fluxdesk/releases/latest/download/latest.json"
      ],
      "pubkey": "PLACEHOLDER_UPDATER_PUBLIC_KEY"
    }
  }
}
